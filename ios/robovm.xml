<config>
    <executableName>MobappGame</executableName>
    <mainClass>io.github.vipaol.mobapp.game.IOSLauncher</mainClass>
    <os>ios</os>
    <arch>thumbv7</arch>
    <target>ios</target>
    <iosInfoPList>Info.plist.xml</iosInfoPList>

    <resources>
        <resource><directory>../res</directory></resource>
    </resources>

    <forceLinkClasses>
        <pattern>mobileapplication3.**</pattern>
